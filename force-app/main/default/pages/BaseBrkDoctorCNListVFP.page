                                                        <apex:outputText escape="false" value="{!$Label.Doc_Category}"/>
                                                    </div>
                                                    <div class="bs col-lg-12 col-xs-12" style="margin-bottom:10px">
                                                        <apex:outputText escape="false" value="{!currentClinic.Hospital_Category__c}"/>
                                                    </div>
                                                    <div class="bs col-lg-12 col-xs-12">
                                                        <apex:outputText escape="false" value="{!$Label.Doc_Type}"/>
                                                    </div>
                                                    <div class="bs col-lg-12 col-xs-12" style="margin-bottom:10px">
                                                        <apex:outputText escape="false" value="{!currentClinic.Clinic_Type__c}"/>
                                                    </div>
                                                    <div class="bs col-lg-12 col-xs-12">
                                                        <apex:outputText escape="false" value="{!$Label.Outpatient_Inpatient}"/>
                                                    </div>
                                                    <div class="bs col-lg-12 col-xs-12" style="margin-bottom:10px">
                                                        <apex:outputText escape="false" value="{!currentClinic.Patient_Type__c}"/>
                                                    </div>
                                                    <div class="bs col-lg-12 col-xs-12">
                                                        <apex:outputText escape="false" value="{!$Label.CN_Doctor_List_Specialty}"/>
                                                    </div>
                                                    <div class="bs col-lg-12 col-xs-12" style="margin-bottom:10px">
                                                        <apex:outputText escape="false" value="{!currentClinic.Specialty__c}"/>
                                                    </div>
                                                    <div class="bs col-lg-12 col-xs-12">
                                                        <apex:outputText escape="false" value="{!$Label.CN_Doctor_List_Language}"/>
                                                    </div>
                                                    <div class="bs col-lg-12 col-xs-12" style="margin-bottom:10px">
                                                        <apex:outputText escape="false" value="{!currentClinic.Language__c}"/>
                                                    </div>
                                                    <div class="bs col-lg-12 col-xs-12">
                                                        <apex:outputText escape="false" value="{!$Label.CN_Doctor_List_Notice}"/>
                                                    </div>
                                                    <div class="bs col-lg-12 col-xs-12" style="margin-bottom:10px">
                                                        <apex:outputText escape="false" value="{!currentClinic.Notice__c}"/>
                                                    </div>
                                                    <div class="bs col-lg-12 col-xs-12">
                                                        <apex:outputText escape="false" value="{!$Label.CN_Doctor_List_Cashless}"/>
                                                    </div>
                                                    <apex:outputPanel rendered="{!lang == 'zh'}">
                                                        <div class="bs col-lg-12 col-xs-12" style="margin-bottom:10px">
                                                            <apex:outputText escape="false" value="{!currentClinic.Cashless_Availability_zh__c}"/>
                                                        </div>
                                                    </apex:outputPanel>
                                                    <apex:outputPanel rendered="{!lang == 'en'}" >
                                                        <div class="bs col-lg-12 col-xs-12" style="margin-bottom:10px">
                                                            <apex:outputText escape="false" value="{!currentClinic.Cashless_Availability_en__c}"/>
                                                        </div>
                                                    </apex:outputPanel>
                                                    <div class="bs col-lg-12 col-xs-12">
                                                        <apex:outputText escape="false" value="{!$Label.CN_Doctor_List_Direct_Billing_Method}"/>
                                                    </div>
                                                    <div class="bs col-lg-12 col-xs-12" style="margin-bottom:10px">
                                                        <apex:outputText escape="false" value="{!currentClinic.Direct_Billing_Method__c}"/>
                                                    </div>
                                                </div>
                                            </div>
                                            <apex:variable var="rowNum" value="{!rowNum + 1}" />
                                        </apex:repeat>
            
                                        <script>
                                            var isIE = /(MSIE|Trident\/|Edge\/)/i.test(navigator.userAgent);
                                            if(isIE){
                                                $('#ListView').css('max-height','360px');
                                                $('#ListView').css('min-height','360px');
                                            }
                                        </script>
                                    </div>
                                </div>

                                <div id="clinic-detail-panel" style="display:none;" class="bs col-sm-12 col-md-12 col-xs-12 col-lg-12">
                                </div>
                                
                            </apex:outputPanel>
                        </div>
                    </apex:outputPanel>
                </div>
                <!-- Statement Label -->
                <div id="doctor-statement" class="bs row">
                    <div class="bs col-sm-12 col-md-12 col-lg-12 col-xs-12" style="text-align: center;font-size: 0.8em;color: #58595B;padding: 10px;">
                        <apex:outputText escape="false" value="{!$Label.CN_Doctor_Statement}"/>
                    </div>
                </div>
                <div id="paginationPanelWrapper">
                <apex:outputPanel id="paginationPanel" layout="block">
                    <apex:outputPanel layout="block" rendered="{!renderShowMore}">
                        <div class="bs col-lg-12 col-xs-12">
                            <div id="pagination-controls" class="doctor-pagination">
                                <apex:outputPanel rendered="{!hasPreviousPage}" layout="none">
                                    <span class="doctor-pagination-link" onclick="Cigna.DrList.loadList({!currentpage - 1});">{!$Label.Page_Previous}</span>
                                </apex:outputPanel>
                                <apex:outputPanel rendered="{!NOT(hasPreviousPage)}" layout="none">
                                    <span class="doctor-pagination-link is-disabled">{!$Label.Page_Previous}</span>
                                </apex:outputPanel>
                                <apex:repeat value="{!paginationPages}" var="pageNumber">
                                    <span class="doctor-pagination-link {!IF(pageNumber = currentpage, 'is-active', '')}" onclick="if ({!pageNumber} != {!currentpage}) { Cigna.DrList.loadList({!pageNumber}); }">{!pageNumber}</span>
                                </apex:repeat>
                                <apex:outputPanel rendered="{!hasNextPage}" layout="none">
                                    <span class="doctor-pagination-link" onclick="Cigna.DrList.loadList({!currentpage + 1});">{!$Label.Page_Next}</span>
                                </apex:outputPanel>
                                <apex:outputPanel rendered="{!NOT(hasNextPage)}" layout="none">
                                    <span class="doctor-pagination-link is-disabled">{!$Label.Page_Next}</span>
                                </apex:outputPanel>
                            </div>
                            <i id="pagination-icon" style="display: none;color:#004986;font-size: 1.5em;margin: 10px;" class="bs spinner-icon fa fa-spinner fa-pulse fa-fw"></i>
                        </div>
                    </apex:outputPanel>
                </apex:outputPanel>
                </div>
                


                <div id="clinic-done" class="bs col-sm-12 col-md-12 col-xs-12 col-lg-12" style="{!IF(currentPanel == 'F','','display:none;')}">
                    <div class="bs row">
                        <div class="bs col-sm-12 col-lg-12 cigna-fg-green-medium" style="font-size: 3.8em;margin-bottom: 10px;text-align: center;padding: 10px 0;">
                            <i class="fa fa-check-circle-o" aria-hidden="true"></i>
                        </div>
                    </div>
                    <div class="bs row">
                        <div class="bs col-md-4 col-xs-0  col-sm-3 col-lg-4"></div>
                        <div class="bs col-md-4 col-xs-12  col-sm-6 col-lg-4" style="text-align: center;font-size: 1em;">
                            <p>{!$Label.Doctor_List_Booking_Done}</p>
                        </div>
                        <div class="bs col-md-4 col-xs-0  col-sm-3 col-lg-4"></div>
                    </div>
                    <div id="action-bar" class="bs visible-xs cigna-floating-bottom-panel" style="left:0px;">
                        <div id="back-btn" class="bs cigna-action-btn-group cigna-fg-white cigna-bg-orange-dark" onclick="DrListAF.backRefresh()">
                            <a class="action-btn cigna-fg-white" role="button">
                                <i class="ci-hk-doctor" aria-hidden="true"></i>
                                <br/>{!$Label.Doctor_List_Back_To_List_Button}
                            </a>
                        </div>
                    </div>
                    <div class="bs row hidden-xs" style="padding-bottom: 20px;">
                        <div class="bs col-sm-4 col-md-4 col-xs-3 col-lg-4 "></div>
                        <div id="back-btn-dt" onclick="DrListAF.backRefresh()" class="bs col-sm-4 col-md-4 onclick-pointer col-xs-6 col-lg-4 mobile-version-button cigna-fg-white cigna-bg-orange-dark desktop-action-btn">
                                {!$Label.Doctor_List_Back_To_List_Button}
                        </div>
                        <div class="bs col-sm-4 col-md-4 col-xs-3 col-lg-4"></div>
                    </div>
                </div>
                <!-- Modal -->
                <div class="modal fade" id="myModal" role="dialog" style="text-align: center;z-index: 8;">
                    <span class="bs loading-helper"></span>
                    <div class="modal-dialog modal-lg">
                        <div class="modal-content">
                            <div class="modal-header" style="padding: 0px;border: none;">
                                <button type="button" class="close" data-dismiss="modal">&times;</button>
                            </div>
                            <div id="modal-clinic-detail" class="modal-body" style="padding-top: 0px; margin-left: 15px; margin-right: 15px;">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </apex:form>
</apex:page>