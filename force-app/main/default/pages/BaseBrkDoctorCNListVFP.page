        <style>

            select::-ms-expand {
                display: none;
            }

            /* hide input */
            .cigna-radio input.radio:empty {
                margin-left: -999px;
            }

            .cigna-radio label {
                width: 120px;
                font-size: 1em;
                font-weight: normal;
            }

            /* style label */
            .cigna-radio input.radio:empty ~ label {
                position: relative;
                float: left;
                line-height: 32px;
                text-indent: 3.25em;
                cursor: pointer;
                -webkit-user-select: none;
                -moz-user-select: none;
                -ms-user-select: none;
                user-select: none;
            }

            .cigna-radio input.radio:empty ~ label:before {
                position: absolute;
                display: block;
                top: 2px;
                bottom: 0;
                left: 0;
                content: '';
            }

            /* toggle on */
            .cigna-radio input.radio:checked:not(:disabled) ~ label:before {
                content:"\f058";
                text-indent: 0.4em;
                color: #39B54A;
                font: normal normal normal 24px/1 FontAwesome;
            }

            .cigna-radio input.radio:not(checked):not(:disabled) ~ label:before {
                content:"\f058";
                text-indent: 0.4em;
                color: #C8C9C7;
                font: normal normal normal 24px/1 FontAwesome;
            }

            .cigna-radio input.radio:disabled ~ label {
                color: #bdb6d6;
            }

            .cigna-radio input.radio:disabled ~ label:before {
                content:"\f058";
                text-indent: 0.4em;
                color: #bdb6d6;
                font: normal normal normal 24px/1 FontAwesome;
            }



