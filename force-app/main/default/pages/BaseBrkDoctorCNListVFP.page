        <script type="text/javascript">
            var changeLanguageWarningRequired = true;
            var tempScrollTop;
            var Cigna = Cigna || {};
            Cigna.DrList = function() {

                function showLabelLoading() {
                    tempScrollTop = $('#ListView').scrollTop();
                    $('#pagination-controls').hide();
                    $('#pagination-icon').fadeIn(100);
                }

                function hideLabelLoading() {
                    $('#ListView').scrollTop(tempScrollTop);
                    $('#pagination-icon').hide();
                    $('#pagination-controls').fadeIn(100);
                }

                var validator;

                //Functions for Loading
                function showLoading() {
                    $('#login-loading').fadeIn(100);
                }

                function finishSubmission() {
                    $('#login-loading').fadeOut(100);
                }

                function loadList(page){
                    showLabelLoading();
                    DrListAF.loadMore(page);
                }

                function openDetail(rowNum) {
                    $('.header-bar').css('position', 'relative');

                    $('#modal-clinic-detail').html($('#clinic-' + rowNum + '-detail').html());
                    $('#modal-clinic-detail #appointment-date').attr("id","appointment-date-target")
                    Cigna.DatepickerUtil.init('#appointment-date-target');
                    $( "#appointment-date-target" ).datepicker("option", { minDate: 0});
                    $('#myModal').modal('show');

                    $('#location-param input[id$="appointed-doctor"]').val($('.modal-content #appointment-doctor').val());
                    $('#location-param input[id$="appointed-time"]').val($('.modal-content #appointment-time').val());

                    $("#list-back-panel").hide();
                }

                //Functions for navigation
                function goBack() {
                    DrListAF.back();
                    $("#searchPanel").hide();
                    $('#myModal').modal('hide');

                }

                function backToSearch() {
                    nextPage();
                    DrListAF.back();
                    $('.header-bar').css('position', 'relative');
                    $('#ListView').css("padding-top", "20px");

                }

                return {
                    showLoading: showLoading,
                    finishSubmission: finishSubmission,
                    openDetail: openDetail,
                    goBack: goBack,
                    backToSearch: backToSearch,
                    showLabelLoading: showLabelLoading,
                    hideLabelLoading: hideLabelLoading,
                    loadList: loadList
                }
            }();

            Cigna.DrList.showLoading();



            $(document).ready(function() {
                //Initialize jQuery Validation
                $("form[id*='myform']").validate({});

                //Binding Button
                //CR-56_Link_20220214
                $("#detail-back-btn").on("click",function() {
                    $("#ListView").show();
                    $("#clinic-detail-panel").hide();
                    $("#detail-back").hide();
                    $("#list-back-panel").show();
                    console.log('detail-back-btn');
                    $("#searchPanel").show();

                    if(!$('#map').is(':visible')){
                        $('.header-bar').css("position", "fixed");
                    }
                });

                $('#myModal').on('shown.bs.modal', function () {
                    $('#modal-clinic-detail').scrollTop(0);
                });

                console.log('isBrokerPortal---'+Cigna.Util.isBrokerPortal());
                if(Cigna.Util.isBrokerPortal){
                    console.log('isBrokerPortal---'+Cigna.Util.isBrokerPortal());
                    $('#HKList').attr('style','display:none');
                    $('#searchPanel').attr('style','display:none');
                    $('#MapPan').hide();
                    $('#backButton').attr('style','display:none');
                    $('#doctor-statement').attr('style','display:none');
                }

            });

            function nextPage() {
                $('#HKList').attr('style','display:block');
                $('#searchPanel').attr('style','display:block');
                $('#MapPan').show();
                $('#backButton').attr('style','display:block');
                $('#doctor-statement').attr('style','display:block');
                $('#paginationPanelWrapper').show();

                $('#initPage').hide();
                $('#nextButton').hide();
            }

            function backPage() {
                $('#HKList').attr('style','display:none');
                $('#searchPanel').attr('style','display:none');
                $('#MapPan').hide();
                $('#backButton').attr('style','display:none');
                $('#doctor-statement').attr('style','display:none');
                $('#paginationPanelWrapper').hide();

                $('#initPage').show();
                $('#nextButton').show();
            }
        </script>
    </head>
    <apex:form id="myform">
        <div id="location-param" style="display: none;">
           
        </div>
        <div class="bs">
            <apex:pageMessages ></apex:pageMessages>
            <!-- For HK List-->
            <apex:actionFunction name="searchKeyWord" action="{!searchClinicByKeyWord}" reRender="TopPanel,paginationPanel" namespace="DrListAF" status="loader-icon">
                <apex:param name="firstParam" assignTo="{!currentpage}" value="1" />
            </apex:actionFunction>
            <apex:actionFunction name="loadMore" action="{!loadMore}" namespace="DrListAF" reRender="TopPanel,paginationPanel" oncomplete="
                Cigna.DrList.hideLabelLoading();">
                <apex:param name="firstParam" assignTo="{!currentpage}" value="" />
            </apex:actionFunction>
            
            <apex:actionFunction name="back" action="{!backToSearch}" namespace="DrListAF"/>
            <apex:actionFunction name="backRefresh" action="{!backToSearchRefresh}" namespace="DrListAF" />

            <apex:actionFunction name="nextBtn" action="{!isEnableNextBtn}" reRender="nextBtn,productName" namespace="DrListAF" status="loader-icon">
            </apex:actionFunction>

            <div class="bs" id="doctor-container">
                <div id="detail-back" class="bs row" style="padding-top: 10px;display:none">
                    <div class="bs col-xs-12">
                        <p><a id="detail-back-btn" href="#" class="bs cigna-fg-orange-medium"><i class="ci-hk-arrow-29" aria-hidden="true"></i>
                                {!$Label.Back}</a>
                        </p>
                    </div>
                </div>
                <div id="list-back-panel" style="{!IF(currentPanel == 'L','','display:none;')}">
                    <div id="list-back" class="bs row visible-xs-block">
                        <div class="bs col-xs-12" style="padding-top: 10px;">
                            <p><a onclick="Cigna.DrList.backToSearch();"  href="#" class="bs cigna-fg-orange-medium"><i class="ci-hk-arrow-29" aria-hidden="true"></i> {!$Label.Back}</a>
                            </p>
                        </div>
                    </div>
                </div>

                <div class="bs row cigna-question-list" id="initPage">
                    <div class="bs col-xs-12 col-sm-12 col-lg-12" style="padding-top: 50px;padding-right: 50px">
                        <apex:outputPanel layout="block" styleClass="bs cigna-quote-question cigna-fg-gray-dark  col-xs-12" >
                            <apex:outputPanel rendered="{!contains(transKey,'~BrkDoctorList_Select~')}">
                                <div class="bs col-sm-12 col-xs-12 cigna-fg-orange-medium">
                                    <div class="bs ci-hk-clipboard ci-hk-lg">
                                    </div>
                                    <b>{!transField['BrkDoctorList_Select'][$Label.Header_Language_Code_Current]}</b>
                                </div>
                            </apex:outputPanel>
                            <br/>
                            <br/>
                            <div id="selectProduct" class="bs col-sm-4 col-xs-4">
                                <apex:selectList style="height:34px;" value="{!selectedPolicyProduct}" size="1" styleClass="bs form-field-style-select" onchange="DrListAF.nextBtn();">
                                    <apex:selectOptions value="{!policyProductList}" />
                                </apex:selectList>
                            </div>
                        </apex:outputPanel>
                    </div>
                </div>
                <!-- next button -->
                <div id="nextButton">
                    <!-- web -->
                    <div class="bs row nextStepBtnIn3" style="padding-top: 20px; padding-bottom: 20px;">
                        <div class="bs col-sm-3 col-md-3 col-xs-3 col-lg-3 "></div>
                        <apex:outputPanel id="nextBtn">
                        <div class="bs col-sm-6 col-md-6 col-xs-6 col-lg-6 onclick-pointer mobile-version-button cigna-fg-white {!IF(enableNextBtn,'cigna-bg-orange-dark','cigna-bg-gray-dark')} desktop-action-btn" 
                            onclick="nextPage();DrListAF.searchKeyWord()" 
                            STYLE="{!IF(enableNextBtn,'','pointer-events: none;')}">
                                {!$Label.Next}
                        </div>
                        </apex:outputPanel>
                    </div>
                </div>
                <!-- Back Button -->
                <div class="bs row" style="padding-top:10px;" id="backButton">
                    <div class="bs col-lg-12 cigna-fg-orange-medium onclick-pointer" onclick="backPage()">
                        <i class="ci-hk-arrow-29 ci-hk-sm" aria-hidden="true"></i> {!$Label.Back}
                    </div>
                </div>
                <!-- Back Button End -->

                <apex:outputPanel >
